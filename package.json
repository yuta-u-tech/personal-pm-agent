{
  "name": "personal-pm-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pm-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
